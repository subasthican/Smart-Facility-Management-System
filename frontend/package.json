{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.6",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "three": "^0.183.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "npm-run-all -p tw:watch start:app",
    "start:app": "react-scripts start",
    "build": "npm run tw:build && react-scripts build",
    "test": "react-scripts test",
    "tw:build": "tailwindcss -i ./src/tailwind.input.css -o ./src/tailwind.generated.css",
    "tw:watch": "tailwindcss -i ./src/tailwind.input.css -o ./src/tailwind.generated.css --watch",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "autoprefixer": "^10.4.27",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17"
  }
}
