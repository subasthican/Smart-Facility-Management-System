# Copy this file to .env.local and fill real values.
# start.sh auto-loads .env.local before starting backend.

# Database overrides (optional)
DB_USERNAME=subasthican
DB_PASSWORD=

# Google OAuth2 (required to enable Google login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
