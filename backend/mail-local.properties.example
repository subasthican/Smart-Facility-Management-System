# Copy this file to: backend/mail-local.properties
# Spring Boot will auto-load mail-local.properties on startup.

# For SLIIT / Microsoft 365 mailboxes, these values are commonly used:
spring.mail.host=smtp.office365.com
spring.mail.port=587
spring.mail.username=YOUR_EMAIL@example.com
spring.mail.password=YOUR_SMTP_PASSWORD_OR_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true

app.password-reset.from-email=YOUR_EMAIL@example.com
app.password-reset.return-code-in-response=false
app.password-reset.code-expiry-minutes=10
